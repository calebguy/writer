{
	"name": "vono",
	"private": "true",
	"type": "module",
	"workspaces": [
		"packages/cli",
		"packages/cron",
		"packages/db",
		"packages/ingestor",
		"packages/previewer",
		"packages/sdk",
		"packages/server",
		"packages/utils",
		"packages/web"
	],
	"devDependencies": {
		"@biomejs/biome": "1.7.3",
		"@types/bun": "latest"
	},
	"peerDependencies": {
		"typescript": "^5.0.0"
	},
	"scripts": {
		"dev": "bun --filter 'db' dev & bun --filter 'server' dev & bun --filter 'ingestor' dev & bun --filter 'web' dev",
		"format": "bunx @biomejs/biome format --write .",
		"db:migrate": "bun --filter 'db' migrate",
		"server:install": "bun --filter 'server' install",
		"server:start": "bun --filter 'server' start",
		"cron:reconcile": "bun --filter 'cron' cron",
		"writer": "bun --filter 'cli' writer"
	},
	"packageManager": "^bun@1.2.0"
}
